generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AssetType {
  OPTION
  STOCK
  FOREX
  FUTURES
  CRYPTO
  INDEX
}

enum TradeSide {
  BUY
  SELL
}

enum PositionSide {
  CALL
  PUT
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id String @id @default(cuid())

  ticker       String
  assetType    AssetType     @default(OPTION)
  side         TradeSide
  positionSide PositionSide?
  status       TradeStatus   @default(CLOSED)

  entryDate DateTime
  exitDate  DateTime?

  entryPrice Float
  exitPrice  Float?

  contracts Int?
  quantity  Float?

  strike     Float?
  expiration DateTime?

  fees       Float  @default(0)
  pnl        Float?
  pnlPercent Float?

  thesis      String?
  notes       String?
  setupTag    String?
  screenshots String[]  @default([])
  exitLegs    ExitLeg[]

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExitLeg {
  id String @id @default(cuid())

  quantity Float
  price    Float
  exitDate DateTime
  note     String?

  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradeId, exitDate])
}

model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  password String

  trades Trade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
